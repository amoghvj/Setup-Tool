# Core server
PORT=3000
MONGODB_URI=mongodb://localhost:27017/optiroute-db
EXAMPLE_API_KEY=
EXAMPLE_ENDPOINT=

# Routing cost weights (must sum close to 1.0)
ROUTE_ALPHA=0.55
ROUTE_BETA=0.20
ROUTE_GAMMA=0.15
ROUTE_DELTA=0.05
ROUTE_EPSILON=0.05

# Routing behavior
ROUTE_EARTH_RADIUS_KM=6371
ROUTE_DEFAULT_SPEED_KPH=35
ROUTE_SERVICE_TIME_MINUTES=0
ROUTE_SLA_PENALTY_MULTIPLIER=1
ROUTE_REGION_PRECISION=100

# Matrix provider options: haversine | osrm | graphhopper | mapbox
MATRIX_PROVIDER=haversine
MATRIX_BASE_URL=
MATRIX_ACCESS_TOKEN=
MATRIX_CACHE_TTL_MINUTES=60
MATRIX_CACHE_MAX_ENTRIES=5000

# Re-optimization controls
REOPTIMIZE_ORDER_THRESHOLD=5
REOPTIMIZE_INTERVAL_MINUTES=15

# OR-Tools batch solver controls
ORTOOLS_ENABLED=false
ORTOOLS_TIME_LIMIT_SECONDS=30
